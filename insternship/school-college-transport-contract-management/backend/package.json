{
  "name": "school-college-transport-backend",
  "version": "1.0.0",
  "description": "Express API for the School & College Transport Contract Management System",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "jest --runInBand --detectOpenHandles",
    "test:coverage": "jest --coverage --runInBand",
    "lint": "eslint src",
    "format": "eslint src --fix",
    "build": "echo \"No build required for backend\""
  },
  "jest": {
    "setupFiles": [
      "<rootDir>/tests/setup.js"
    ]
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "dotenv-validator": "^1.0.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.7.0",
    "helmet": "^8.2.0",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.11.0",
    "node-cron": "^3.0.3",
    "pdfkit": "^0.15.2",
    "pg": "^8.13.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.9",
    "supertest": "^7.2.2"
  }
}
