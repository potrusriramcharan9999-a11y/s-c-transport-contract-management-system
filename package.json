{
  "name": "school-college-transport-contract-management",
  "version": "1.0.0",
  "description": "Transport Contract Management System",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "test:backend": "npm test --prefix backend",
    "test:frontend": "npm test --prefix frontend",
    "test": "npm run test:backend && npm run test:frontend",
    "lint:backend": "npm run lint --prefix backend",
    "lint:frontend": "npm run lint --prefix frontend",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "format:backend": "npm run format --prefix backend",
    "format:frontend": "npm run format --prefix frontend",
    "format": "npm run format:backend && npm run format:frontend"
  }
}
